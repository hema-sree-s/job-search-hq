# These are only needed if you run `vercel dev` locally. On the actual
# deployment, set these in Vercel -> Project -> Settings -> Environment Variables
# instead -- this file is not read by Vercel in production.

# Any long random string -- used to sign login sessions (not the same as
# the encryption key, which is derived from each user's password in the browser).
JWT_SECRET=

# Auto-filled if you connect an Upstash Redis database from Vercel's Storage tab.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Auto-filled if you connect a Vercel Blob store from Vercel's Storage tab.
# Needed for the Documents (PDF upload) feature.
BLOB_READ_WRITE_TOKEN=

# Optional. Enables "AI coaching" / "AI tailoring tips" / "Get suggestions"
# (study topics & certifications) buttons. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional. Enables the "Continue with Google" button. See README for how to
# get one from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
